{
  "name": "@okdoc/plugin-sdk",
  "version": "0.5.0",
  "description": "SDK for building OkDoc AI-powered plugins — decorators, types, and notifier for MCP tool integration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:iframe": "node scripts/build-iframe-sdk.mjs",
    "build:all": "tsc && node scripts/build-iframe-sdk.mjs",
    "prepublishOnly": "npm run build:all"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0"
  },
  "devDependencies": {
    "@angular/core": "^20.0.0",
    "esbuild": "^0.27.3",
    "typescript": "~5.8.0"
  },
  "license": "MIT",
  "sideEffects": false
}
