# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

# NOTE: This is generated by Claude 4.5 sonnet.

# ============================================
# Node.js & Dependencies
# ============================================
/node_modules
npm-debug.log
yarn-error.log
yarn.log
.pnpm-debug.log
package-lock.json  # Optional: remove this line if you want to track it
.npm
.yarn-integrity

# ============================================
# Ionic & Capacitor
# ============================================
/.ionic
/www
/platforms
/plugins
capacitor.config.json  # Keep only if it contains sensitive data
.sourcemaps
.versions

# ============================================
# Angular
# ============================================
/.angular
/.angular/cache
/dist
/tmp
/out-tsc
/bazel-out

# ============================================
# Testing & Coverage
# ============================================
/coverage
/.nyc_output
testem.log
/typings
*.spec.ts.map

# Karma
/karma-reports
karma-debug.log

# ============================================
# Build Outputs
# ============================================
*.js.map
*.css.map
*.ngfactory.ts
*.ngsummary.json
*.shim.ts

# ============================================
# Environment & Configuration
# ============================================
# Uncomment the following if you have environment-specific files with secrets
# /src/environments/environment.ts
# /src/environments/environment.prod.ts
.env
.env.local
.env.*.local

# ============================================
# IDEs and Editors
# ============================================
# JetBrains IDEs (WebStorm, IntelliJ IDEA, etc.)
.idea/
*.iml
*.ipr
*.iws

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Eclipse
.project
.classpath
.c9/
*.launch
.settings/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*~
*.sw[mnpcod]
*.swp
*.swo
*~
Session.vim

# ============================================
# Logs
# ============================================
*.log
log.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================
# OS Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# Temporary Files
# ============================================
.tmp
*.tmp
*.tmp.*
*.bak
*.swp
*.swo
*~.nib
.cache

# ============================================
# Capacitor Specific
# ============================================
# Android - built by Capacitor
android/app/src/main/assets/public
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
android/capacitor-cordova-android-plugins

# iOS - built by Capacitor
ios/App/public
ios/App/App/capacitor.config.json
ios/App/App/config.xml
ios/capacitor-cordova-ios-plugins

# ============================================
# Mobile Platform Specific
# ============================================
# Android signing keys - NEVER commit these!
*.jks
*.keystore
google-services.json  # Add if contains sensitive Firebase keys
keystore.properties

# iOS provisioning
*.mobileprovision
*.p12
*.cer

# ============================================
# Package Managers
# ============================================
.nx
.nx/cache
.pnp
.pnp.js

# ============================================
# Miscellaneous
# ============================================
.sass-cache/
/connect.lock
/libpeerconnection.log
UserInterfaceState.xcuserstate

# Debug
npm-debug.log*
.vscode-test
